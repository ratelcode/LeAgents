# LeAgents — user-level environment variables.
# Copy to .env, fill in what you use, then `source .env` (or use direnv).
# .env is gitignored; never commit real tokens.

# ── Publishing (maintainers only) ───────────────────────────────────────
# PyPI API token for publishing the `leagents` package (pypi.org → Account
# settings → API tokens). Used by `uv publish` / twine.
UV_PUBLISH_TOKEN=pypi-xxxxxxxxxxxxxxxxxxxxxxxx
# twine equivalents, if you publish with twine instead:
# TWINE_USERNAME=__token__
# TWINE_PASSWORD=pypi-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Hugging Face ────────────────────────────────────────────────────────
# Needed only for private datasets or pushing datasets/checkpoints to the
# Hub. Public dataset downloads (HuggingFaceVLA/libero, lerobot/pusht) work
# without it.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# Override the LeRobot dataset cache location (default ~/.cache/huggingface/lerobot):
# HF_LEROBOT_HOME=/data/lerobot-cache

# ── LLM adapter (optional — everything falls back to deterministic) ─────
# Only needed when the loop config sets `llm:` (proposer + knowledge lessons).
# SDKs: pip install "leagents[llm]"
# Gemini has a free tier (aistudio.google.com → Get API key):
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx   # llm: "gemini:gemini-2.5-flash"
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx             # llm: "anthropic:claude-sonnet-5"
# OPENAI_API_KEY=sk-xxxxxxxx                    # llm: "openai:gpt-5.2"
# Local OpenAI-compatible servers (Ollama/vLLM) need no key:
#   llm: "openai:<model>@http://localhost:11434/v1"

# ── Headless simulation (Linux) ─────────────────────────────────────────
# Required for LIBERO eval / rollout collection without a display.
MUJOCO_GL=egl
SDL_VIDEODRIVER=dummy

# ── Install-time only ───────────────────────────────────────────────────
# CMake 4.x rejects egl-probe's old CMakeLists during `pip install
# "leagents[lerobot]"`; export this for the install, then it can be unset.
# CMAKE_POLICY_VERSION_MINIMUM=3.5
